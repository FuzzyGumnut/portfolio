```html
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bowen Duff</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
:root{
    --bg:#0b0c0f;
    --surface:#111318;
    --border:#22252b;
    --text:#f5f5f5;
    --muted:#8b8f98;
    --accent:#84ff8f;
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    background:var(--bg);
    color:var(--text);
    font-family:'JetBrains Mono', monospace;
    line-height:1.7;
}

.container{
    width:min(1100px,90%);
    margin:auto;
}

nav{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:40px 0;
}

.logo{
    font-size:1.4rem;
    font-weight:600;
}

.nav-links{
    display:flex;
    gap:2rem;
}

.nav-links a{
    color:var(--text);
    text-decoration:none;
    transition:.3s;
}

.nav-links a:hover{
    color:var(--accent);
}

.hero{
    min-height:80vh;
    display:flex;
    align-items:center;
}

.hero h1{
    font-size:clamp(2rem,5vw,4rem);
    max-width:900px;
    font-weight:400;
}

.hero span{
    color:var(--accent);
}

.btn{
    display:inline-block;
    margin-top:2rem;
    padding:14px 24px;
    background:var(--surface);
    border:1px solid var(--border);
    color:white;
    text-decoration:none;
    transition:.3s;
}

.btn:hover{
    border-color:var(--accent);
    transform:translateY(-2px);
}

section{
    padding:120px 0;
    border-top:1px solid var(--border);
}

.section-title{
    font-size:2rem;
    margin-bottom:2rem;
}

.about p{
    color:var(--muted);
    max-width:850px;
}

.skills{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:2rem;
    margin-top:3rem;
}

.skill-box{
    border:1px solid var(--border);
    padding:1.5rem;
    background:var(--surface);
}

.skill-box h3{
    margin-bottom:1rem;
    color:var(--accent);
}

.skill-box ul{
    list-style:none;
}

.skill-box li{
    margin-bottom:.5rem;
    color:var(--muted);
}

.projects-grid{
    display:grid;
    gap:1.5rem;
    margin-top:2rem;
}

.project-card{
    border:1px solid var(--border);
    background:var(--surface);
    padding:2rem;
    transition:.3s;
}

.project-card:hover{
    border-color:var(--accent);
    transform:translateY(-4px);
}

.project-card h3{
    margin-bottom:.8rem;
}

.project-card p{
    color:var(--muted);
    margin-bottom:1rem;
}

.project-card a{
    color:var(--accent);
    text-decoration:none;
}

.stats{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:2rem;
    margin-top:2rem;
}

.stats img{
    width:100%;
}

.contact-links{
    display:flex;
    flex-wrap:wrap;
    gap:1rem;
    margin-top:2rem;
}

.contact-links a{
    text-decoration:none;
    color:white;
    border:1px solid var(--border);
    padding:12px 18px;
    transition:.3s;
}

.contact-links a:hover{
    border-color:var(--accent);
}

footer{
    padding:60px 0;
    text-align:center;
    color:var(--muted);
    border-top:1px solid var(--border);
}

.loading{
    color:var(--muted);
}

@media(max-width:768px){
    nav{
        flex-direction:column;
        gap:1rem;
    }

    .nav-links{
        flex-wrap:wrap;
        justify-content:center;
    }
}
</style>
</head>
<body>

<div class="container">

<nav>
    <div class="logo">BowenDuff.</div>

    <div class="nav-links">
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
        <a href="#skills">Skills</a>
        <a href="#contact">Contact</a>
    </div>
</nav>

<section class="hero">
    <div>
        <h1>
            I'm <span>Bowen Duff</span>, a full-stack developer,
            embedded systems enthusiast, and SDR hobbyist
            building web apps, LoRa networks, and custom macOS workflows.
        </h1>

        <a href="#projects" class="btn">View Projects →</a>
    </div>
</section>

<section id="about" class="about">
    <h2 class="section-title">About Me</h2>

    <p>
        I'm a developer from Victoria, Australia.
        I enjoy building practical software, experimenting with radio
        communications, developing embedded systems, and customising
        macOS into a Linux-inspired workflow.
        <br><br>
        My interests include full-stack development, SDR, LoRa networking,
        embedded systems, open-source software, and UI/UX design.
    </p>
</section>

<section id="projects">
    <h2 class="section-title">Projects</h2>

    <div id="projects-container" class="projects-grid">
        <p class="loading">Loading repositories...</p>
    </div>
</section>

<section id="skills">
    <h2 class="section-title">Skills</h2>

    <div class="skills">

        <div class="skill-box">
            <h3>Languages</h3>
            <ul>
                <li>Python</li>
                <li>JavaScript</li>
                <li>TypeScript</li>
                <li>C</li>
                <li>C++</li>
            </ul>
        </div>

        <div class="skill-box">
            <h3>Technologies</h3>
            <ul>
                <li>React</li>
                <li>Node.js</li>
                <li>Docker</li>
                <li>Git</li>
                <li>STM32</li>
                <li>Arduino</li>
            </ul>
        </div>

        <div class="skill-box">
            <h3>Tools</h3>
            <ul>
                <li>Ghostty</li>
                <li>AeroSpace</li>
                <li>SketchyBar</li>
                <li>Starship</li>
                <li>Linux</li>
                <li>macOS</li>
            </ul>
        </div>

    </div>
</section>

<section id="github">
    <h2 class="section-title">GitHub Stats</h2>

    <div class="stats">
        <img src="https://github-readme-stats.vercel.app/api?username=FuzzyGumnut&show_icons=true&theme=transparent" alt="">
        <img src="https://github-readme-stats.vercel.app/api/top-langs/?username=FuzzyGumnut&layout=compact&theme=transparent" alt="">
    </div>
</section>

<section id="contact">
    <h2 class="section-title">Contact</h2>

    <div class="contact-links">
        <a href="https://github.com/FuzzyGumnut" target="_blank">GitHub</a>
        <a href="mailto:your@email.com">Email</a>
    </div>
</section>

<footer>
    © 2026 Bowen Duff
</footer>

</div>

<script>
const container = document.getElementById("projects-container");

async function loadRepos() {
    try {
        const response = await fetch(
            "https://api.github.com/users/FuzzyGumnut/repos?sort=updated"
        );

        const repos = await response.json();

        container.innerHTML = "";

        repos
            .filter(repo => !repo.fork)
            .slice(0, 8)
            .forEach(repo => {

                const card = document.createElement("div");
                card.className = "project-card";

                card.innerHTML = `
                    <h3>${repo.name}</h3>
                    <p>${repo.description || "No description available."}</p>
                    <a href="${repo.html_url}" target="_blank">
                        View Repository →
                    </a>
                `;

                container.appendChild(card);
            });

    } catch (error) {
        container.innerHTML =
            "<p>Failed to load repositories.</p>";
    }
}

loadRepos();
</script>

</body>
</html>
